# Copy to .env (or export in your shell) and fill in.

# N2YO API key — used by dashboard/app.py to fetch live positions for a handful
# of well-known satellites (ISS, Hubble, ...). Free tier: https://www.n2yo.com/api/
# Optional: without it the dashboard uses simulated positions.
N2YO_API_KEY="your_n2yo_api_key_here"
